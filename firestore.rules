rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Conversations
    match /conversations/{conversationId} {
      allow get: if request.auth != null && (
        resource == null || 
        resource.data.userId == request.auth.uid
      );
      allow list: if request.auth != null && 
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
        resource.data.userId == request.auth.uid && 
        request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }

    // Users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admins
    match /admins/{adminId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Analytics Summary (Accessed by the unauthenticated server)
    match /analytics/{docId} {
      allow read, write: if true;
    }

    // Chat Logs (Accessed by the unauthenticated server)
    match /chat_logs/{logId} {
      allow read, write: if true;
    }

    // Daily Usage (Accessed by the unauthenticated server)
    match /daily_usage/{date} {
      allow read, write: if true;
      
      match /active_sessions/{sessionId} {
        allow read, write: if true;
      }
    }

    // Feedback Collection (Accessed by the unauthenticated server)
    match /feedback/{feedbackId} {
      allow read, write: if true;
    }

    // Performance Logs (Accessed by the unauthenticated server)
    match /performance_logs/{logId} {
      allow read, write: if true;
    }

    // Knowledge Stats (Accessed by the unauthenticated server)
    match /knowledge_stats/{docId} {
      allow read, write: if true;
    }

    // Frequent Questions (Accessed by the unauthenticated server)
    match /frequent_questions/{questionId} {
      allow read, write: if true;
    }

    // Notices (Accessed by the unauthenticated server)
    match /notices/{noticeId} {
      allow read, write: if true;
    }

    // FAQs (Accessed by the unauthenticated server)
    match /faqs/{faqId} {
      allow read, write: if true;
    }

    // AI Settings (Accessed by the unauthenticated server)
    match /ai_settings/{settingId} {
      allow read, write: if true;
    }

    // AI Logs (Accessed by the unauthenticated server)
    match /ai_logs/{logId} {
      allow read, write: if true;
    }

    // Audit Logs (Accessed by the unauthenticated server)
    match /audit_logs/{logId} {
      allow read, write: if true;
    }

    // AI Execution Logs (Accessed by the unauthenticated server)
    match /analytics_ai_logs/{logId} {
      allow read, write: if true;
    }

    // Popular Documents (Accessed by the unauthenticated server)
    match /popular_documents/{docId} {
      allow read, write: if true;
    }

    // Knowledge Collection (Accessed by the unauthenticated server)
    match /knowledge/{docId} {
      allow read, write: if true;
    }
  }
}
